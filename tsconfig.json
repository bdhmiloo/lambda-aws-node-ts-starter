{
  "compilerOptions": {
    "target": "es2022",
    "composite": false,
    "declaration": true,
    "declarationMap": false,
    "esModuleInterop": true,
    "forceConsistentCasingInFileNames": true,
    "inlineSources": false,
    "isolatedModules": true,
    "moduleResolution": "node",
    "noUnusedLocals": false,
    "noUnusedParameters": false,
    "preserveWatchOutput": true,
    "skipLibCheck": true,
    "strict": true,
    "rootDir": "src",
    "outDir": "build"
  },
  "include": [
    "src",
    "src/types.d.ts"
  ],
  "exclude": [
    "node_modules"
  ],
  "typeRoots": [
    "types"
  ]
}
